{
    "name": "spacebuilder",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "oxlint src",
        "lint:fix": "oxlint src --fix",
        "fmt": "oxfmt --check src",
        "fmt:fix": "oxfmt --write src",
        "prepare": "husky",
        "typecheck": "tsc --noEmit",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate"
    },
    "dependencies": {
        "@types/animejs": "^3.1.13",
        "@types/three": "^0.184.1",
        "animejs": "^4.5.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "lenis": "^1.3.23",
        "lucide-react": "^0.469.0",
        "motion": "^12.40.0",
        "next": "16.2.9",
        "pg": "^8.22.0",
        "radix-ui": "^1.6.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "resend": "^6.14.0",
        "shadcn": "^4.11.0",
        "tailwind-merge": "^3.6.0",
        "three": "^0.184.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "drizzle-kit": "^0.31.10",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.4",
        "oxfmt": "^0.55.0",
        "oxlint": "^1.71.0",
        "tailwindcss": "^4",
        "typescript": "^5"
    },
    "allowScripts": {
        "sharp@0.34.5": true,
        "unrs-resolver@1.12.2": true,
        "husky@9.1.7": true
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "oxlint --fix"
        ],
        "*.{ts,tsx,css,json,md}": [
            "oxfmt --write"
        ]
    }
}
